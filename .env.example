# Local API (Wrangler dev default). Copy to .env for later phases.
VITE_API_URL=http://localhost:8787

# Public site origin for shareable form links (defaults to https://servewellsystems.com).
# VITE_PUBLIC_SITE_URL=http://localhost:5173

# Optional: override seeded demo admin used for silent /demo/admin sign-in (not shown in UI).
# VITE_DEMO_ADMIN_EMAIL=church@example.com
# VITE_DEMO_ADMIN_PASSWORD=temporary-password
